{
  "name": "fullstack-ecosystem",
  "version": "0.1.2",
  "description": "Engine CLI para orquestar ecosistemas Fullstack unificados",
  "main": "dist/src/cli/index.js",
  "bin": {
    "fullstack_ecosystem": "bin/fullstack_ecosystem.ts"
  },
  "scripts": {
    "build:cli": "tsc",
    "fullstack_ecosystem": "ts-node bin/fullstack_ecosystem.ts",
    "init": "ts-node bin/fullstack_ecosystem.ts init",
    "validate": "ts-node bin/fullstack_ecosystem.ts validate app.yaml",
    "build": "ts-node bin/fullstack_ecosystem.ts build app.yaml",
    "dev": "ts-node bin/fullstack_ecosystem.ts dev app.yaml"
  },
  "keywords": [
    "cli",
    "fullstack",
    "orchestrator",
    "yaml"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "yaml": "^2.9.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
